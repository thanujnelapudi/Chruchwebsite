---
import Layout from "@/layouts/Layout.astro";
import SermonsView from "@/components/pages/SermonsView";
import { getSermons, getSermonSeries } from "@/lib/sanity";

const [sermons, allSeries] = await Promise.all([
  getSermons().catch(() => []),
  getSermonSeries().catch(() => []),
]);
---

<Layout title="Sermons" description="Browse our full sermon archive. Watch messages and download sermon notes.">
  <SermonsView sermons={sermons} allSeries={allSeries} client:load />
</Layout>
