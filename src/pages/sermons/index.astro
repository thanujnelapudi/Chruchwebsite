---
import Layout from "@/layouts/Layout.astro";
import SermonSearch from "@/components/islands/SermonSearch";
import { getSermons, getSermonTopics, getSermonSeries } from "@/lib/sanity";
import { BookOpen } from "lucide-react";

const [sermons, topics, allSeries] = await Promise.all([
  getSermons(),
  getSermonTopics(),
  getSermonSeries(),
]);
---

<Layout
  title="Sermons"
  description="Browse our full sermon archive. Watch, read sermon notes, and search by speaker, topic, or series."
>
  <!-- Hero -->
  <section class="pt-24 pb-16 px-6 bg-primary">
    <div class="max-w-[100rem] mx-auto text-center">
      <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <BookOpen className="w-8 h-8 text-white" />
      </div>
      <h1 class="font-heading text-5xl md:text-6xl text-white mb-6">
        SERMONS
      </h1>
      <p class="font-paragraph text-xl text-white/90 max-w-3xl mx-auto">
        Grow in faith through the teaching of God's Word. Watch, read notes,
        and search our full archive.
      </p>
      <div class="flex flex-wrap justify-center gap-6 mt-10 text-white/70 font-paragraph text-sm">
        <span>{sermons.length} messages</span>
        <span>·</span>
        <span>{topics.length} topics</span>
        {allSeries.length > 0 && (
          <>
            <span>·</span>
            <span>{allSeries.length} series</span>
          </>
        )}
      </div>
    </div>
  </section>

  <!-- Search island: receives all data at SSR time, runs search client-side -->
  <section class="py-12 min-h-[60vh]">
    <SermonSearch
      sermons={sermons}
      topics={topics}
      allSeries={allSeries}
      client:load
    />
  </section>
</Layout>
