---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Page Not Found" noindex={true}>
  <div class="min-h-screen bg-background dark:bg-slate-900 flex items-center justify-center px-6 pt-24">
    <div class="text-center max-w-md">
      <div class="w-24 h-24 bg-primary/10 dark:bg-white/10 rounded-full flex items-center justify-center mx-auto mb-8">
        <span class="font-heading text-5xl text-primary dark:text-blue-300">?</span>
      </div>
      <h1 class="font-heading text-5xl text-primary dark:text-blue-300 mb-4">Page Not Found</h1>
      <p class="font-paragraph text-lg text-foreground/70 dark:text-white/60 mb-10">
        Sorry, we couldn't find that page. It may have moved or no longer exists.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="bg-primary hover:bg-primary/90 text-white font-paragraph px-8 py-4 transition-colors"
        >
          Return Home
        </a>
        <a
          href="/sermons"
          class="border border-primary/30 dark:border-white/20 text-primary dark:text-white hover:bg-primary hover:text-white hover:border-primary font-paragraph px-8 py-4 transition-colors"
        >
          Browse Sermons
        </a>
      </div>
    </div>
  </div>
</Layout>
