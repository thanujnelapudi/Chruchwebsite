---
import Header from "@/components/Header";
import Footer from "@/components/Footer";
import "@/styles/global.css";
import design from "../../config/design.json";
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "The Pillar of Cloud Tabernacle — End Time Message Church in Hyderabad, India. A Spirit-filled congregation under Pastor K. Andrew. Join us for Sunday worship at 10:00 AM. Watch live on YouTube.",
  image = "/images/og-default.jpg",
  noindex = false,
} = Astro.props;

const siteTitle = design.brand.name;
const fullTitle  = title ? `${title} | ${siteTitle}` : "The Pillar of Cloud Tabernacle | End Time Message Church Hyderabad";
---

<html lang="en" class="w-full h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="The Pillar of Fire Ministries, the Church in Hyderabad, End Time Message Church Hyderabad, Moula Ali, Pillar of Cloud Tabernacle, End Time Church" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={Astro.url.href} />

    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:url"         content={Astro.url.href} />
    <meta property="og:site_name"   content={siteTitle} />

    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Alex+Brush&family=Dancing+Script:wght@400;500;600;700&family=Herr+Von+Muellerhoff&display=swap" rel="stylesheet" />

    <link rel="icon"             type="image/png" href="/icons/favicon.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="theme-color" content="#1E3A8A" />

    {/* Preload High-Priority Hero Background Assets to Prevent Flicker */}
    {Astro.url.pathname === '/' && (
      <>
        <link rel="preload" as="image" href="https://static.wixstatic.com/media/9e129b_7c11a873db554fe6b146a8648d43d667~mv2.png" />
        <link rel="preload" as="video" href="/videos/hero-clouds.mp4" type="video/mp4" />
      </>
    )}

    {/* Google Analytics (Replace G-YOUR_MEASUREMENT_ID with actual ID) */}
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-YOUR_MEASUREMENT_ID"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-YOUR_MEASUREMENT_ID');
    </script>
  </head>

  <body class="w-full min-h-full bg-background text-foreground">
    <!-- Fixed header -->
    <Header client:load />

    <main class="w-full flex-grow">
      <slot />
    </main>

    <Footer client:load />
    <Analytics />

    {/* Invisible JSON-LD Structured Data for Google SEO */}
    {Astro.url.pathname === '/' && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Church",
        "name": "The Pillar of Cloud Tabernacle",
        "alternateName": "The Pillar of Fire Ministries",
        "description": "End Time Message Church in Hyderabad, India. A Spirit-filled congregation following the teachings of the end time message. Located in Moula Ali, Hyderabad, Telangana.",
        "url": "https://thepillaroffireministries.vercel.app",
        "telephone": "",
        "email": "thepillarofcloudtabernacle@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Moula Ali",
          "addressLocality": "Hyderabad",
          "addressRegion": "Telangana",
          "postalCode": "500040",
          "addressCountry": "IN"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "17.4239",
          "longitude": "78.5671"
        },
        "openingHours": [
          "Su 10:00-12:00",
          "We 19:00-20:00",
          "Fr 10:30-12:00",
          "Fr 19:00-20:30"
        ],
        "sameAs": [
          "https://www.youtube.com/@PastorK.Andrew"
        ],
        "keywords": "End Time Message Church Hyderabad, Pillar of Cloud Tabernacle, Pillar of Fire Ministries, Pastor K Andrew, Message Church India, William Branham Message Church Hyderabad, Moula Ali Church"
      })} />
    )}
  </body>
</html>
