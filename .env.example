# =============================================================================
# PCT Church Website — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API
SANITY_PROJECT_ID=your_project_id_here
SANITY_DATASET=production

# Read-only token for server-side data fetching (safe to use in SSR)
# Create at: Sanity Manage → API → Tokens → "Viewer" role
SANITY_API_TOKEN=your_read_token_here

# Write token for API routes (contact form, prayer requests)
# Create at: Sanity Manage → API → Tokens → "Editor" role
# IMPORTANT: Never expose this token client-side
SANITY_WRITE_TOKEN=your_write_token_here

# ── Cloudflare R2 (Sermon PDFs) ───────────────────────────────────────────────
# Get from Cloudflare Dashboard → R2 → your bucket
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=pct-sermons
R2_PUBLIC_URL=https://pub-c0ea559d9e3b44439fe9f2006b1ea8bb.r2.dev

# ── Site ──────────────────────────────────────────────────────────────────────
# The canonical URL of the deployed site (no trailing slash)
PUBLIC_SITE_URL=https://pct.vercel.app

# YouTube Channel ID for the live stream embed
# Find at: YouTube Studio → Customization → Basic Info → Channel ID
PUBLIC_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
